# PostgreSQL connection string for the smart_disk_monitor database
DATABASE_URL=postgresql://user:password@hostname:5432/smart_disk_monitor

# How often the agent polls for SMART data, in seconds (default: 300 = 5 minutes)
AGENT_POLLING_INTERVAL_SECONDS=300

# Per-device smartctl subprocess timeout, in seconds (default: 30)
AGENT_DEVICE_TIMEOUT_SECONDS=30

# Port the web server listens on (default: 8080)
WEB_PORT=8080

# Logging level for agent and web server (default: INFO)
LOG_LEVEL=INFO
